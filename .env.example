# ScropIDS Docker Environment Configuration

# Backend Configuration
DJANGO_SECRET_KEY=scropids-docker-demo-secret
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,backend
SCROPIDS_ENCRYPTION_KEY=scropids-docker-demo-encryption-key

# Database Configuration
POSTGRES_DB=scropids
POSTGRES_USER=scropids
POSTGRES_PASSWORD=scropids

# Frontend Configuration
FRONTEND_ORIGIN=http://localhost
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,https://localhost,https://127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1,https://localhost,https://127.0.0.1

# Security Settings
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_SSL_REDIRECT=False
SCROPIDS_ADMIN_LOCALHOST_ONLY=True
SCROPIDS_ADMIN_LOCAL_HOSTS=localhost,127.0.0.1,::1

# Bootstrap Configuration
SCROPIDS_BOOTSTRAP_ENABLED=True
SCROPIDS_BOOTSTRAP_FORCE_RESET=False
SCROPIDS_BOOTSTRAP_ADMIN_USERNAME=admin
SCROPIDS_BOOTSTRAP_ADMIN_PASSWORD=admin
SCROPIDS_BOOTSTRAP_NORMAL_USERNAME=normal
SCROPIDS_BOOTSTRAP_NORMAL_PASSWORD=normal
SCROPIDS_BOOTSTRAP_WORKSPACE_NAME=ScropIDS Workspace
SCROPIDS_BOOTSTRAP_NORMAL_ROLE=analyst
SCROPIDS_BOOTSTRAP_LLM_PROVIDER_NAME=OpenRouter Gemma 4 31B Free
SCROPIDS_BOOTSTRAP_LLM_PROVIDER_TYPE=openai_compatible
SCROPIDS_BOOTSTRAP_LLM_BASE_URL=https://openrouter.ai/api/v1
SCROPIDS_BOOTSTRAP_LLM_MODEL=google/gemma-4-31b-it:free
SCROPIDS_BOOTSTRAP_LLM_TIMEOUT_SECONDS=60
SCROPIDS_BOOTSTRAP_LLM_API_KEY=

# Agent Configuration (for Docker agent service)
# After running bootstrap, copy the agent access token from the output:
SCROPIDS_AGENT_API_BASE=http://backend:8000/api/v1
SCROPIDS_AGENT_ORG_SLUG=scropids-workspace
SCROPIDS_AGENT_ORG_ACCESS_TOKEN=your-agent-access-token-here
SCROPIDS_AGENT_HOSTNAME=docker-agent-01

# Image tags
SCROPIDS_BACKEND_IMAGE=scropids/backend:demo
SCROPIDS_FRONTEND_IMAGE=scropids/frontend:demo
SCROPIDS_AGENT_IMAGE=scropids/agent:demo
